
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Publicly readable files, admin-only writes
    match /files/{fileId} {
      allow read: if true;
      allow write: if isAdmin();

      // Anyone can read reviews, anyone can create ONE review per IP
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if true; // In production, you'd use a Cloud Function or complex rules to verify IP uniqueness
        allow update, delete: if isAdmin();
      }
    }

    // Publicly readable tags, admin-only writes
    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User-specific application settings
    match /users/{userId}/appConfigurations/{configId} {
      allow read, write: if isOwner(userId);
    }

    // Public profile data
    match /public_profiles/{profileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin role verification
    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
