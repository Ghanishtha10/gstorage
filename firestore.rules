rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * G STORAGE SECURITY RULES
     * 
     * Simplified for a prototype environment.
     * Access is granted based on signed-in status and roles.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description In this prototype, any authenticated user is treated as an admin.
     */
    function isAdmin() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /files/{fileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/appConfigurations/{configId} {
      allow read, write: if isOwner(userId);
    }

    match /global_configs/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /public_profiles/{profileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}