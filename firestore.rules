rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * G STORAGE SECURITY RULES
     * 
     * Simplified for a single-admin environment.
     * Anyone signed in is treated as an administrator.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description In this prototype, any authenticated user is the admin.
     * We also check for the specific admin email as a fallback.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@gstorage.com" || 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        true // Simplification for prototype access
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /files/{fileId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /tags/{tagId} {
      allow get, list: if true; // Allow public to see tags for filtering
      allow write: if isAdmin();
    }

    match /users/{userId}/appConfigurations/{configId} {
      allow read, write: if isOwner(userId);
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow write: if false; 
    }
  }
}