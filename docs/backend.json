
{
  "entities": {
    "File": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "File",
      "type": "object",
      "description": "Represents an uploaded file, including its metadata and relationships to tags.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the File entity."
        },
        "filename": {
          "type": "string",
          "description": "The original name of the uploaded file."
        },
        "fileUrl": {
          "type": "string",
          "description": "The URL or path where the file content is stored.",
          "format": "uri"
        },
        "mimeType": {
          "type": "string",
          "description": "The MIME type of the file (e.g., 'image/jpeg', 'application/pdf')."
        },
        "sizeBytes": {
          "type": "number",
          "description": "The size of the file in bytes."
        },
        "uploadedAt": {
          "type": "string",
          "description": "Timestamp indicating when the file was uploaded.",
          "format": "date-time"
        },
        "tagIds": {
          "type": "array",
          "description": "References to Tag entities associated with this file.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "filename",
        "fileUrl",
        "mimeType",
        "sizeBytes",
        "uploadedAt"
      ]
    },
    "Tag": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tag",
      "type": "object",
      "description": "Represents a content tag used for organizing files, potentially suggested by AI.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Tag entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the tag."
        },
        "isAISuggested": {
          "type": "boolean",
          "description": "Indicates if this tag was suggested by AI."
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Review": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Review",
      "type": "object",
      "description": "A user-submitted review for a specific file, restricted by IP address.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the review."
        },
        "rating": {
          "type": "number",
          "description": "Star rating from 1 to 5."
        },
        "comment": {
          "type": "string",
          "description": "Textual feedback from the user."
        },
        "ipAddress": {
          "type": "string",
          "description": "The IP address of the reviewer used for restriction."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of the review.",
          "format": "date-time"
        }
      },
      "required": [
        "rating",
        "comment",
        "ipAddress",
        "createdAt"
      ]
    },
    "AppConfiguration": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppConfiguration",
      "type": "object",
      "description": "Stores global application settings.",
      "properties": {
        "id": {
          "type": "string"
        },
        "isDarkModeEnabled": {
          "type": "boolean"
        },
        "selectedAccentColorHex": {
          "type": "string"
        },
        "lastUpdatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "isDarkModeEnabled",
        "selectedAccentColorHex",
        "lastUpdatedAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/files/{fileId}",
        "definition": {
          "entityName": "file",
          "schema": {
            "$ref": "#/backend/entities/File"
          },
          "description": "Metadata for uploaded files."
        }
      },
      {
        "path": "/files/{fileId}/reviews/{reviewId}",
        "definition": {
          "entityName": "review",
          "schema": {
            "$ref": "#/backend/entities/Review"
          },
          "description": "Reviews for a specific file, scoped by file ID."
        }
      },
      {
        "path": "/tags/{tagId}",
        "definition": {
          "entityName": "tag",
          "schema": {
            "$ref": "#/backend/entities/Tag"
          },
          "description": "Content categorization tags."
        }
      },
      {
        "path": "/users/{userId}/appConfigurations",
        "definition": {
          "entityName": "appConfiguration",
          "schema": {
            "$ref": "#/backend/entities/AppConfiguration"
          },
          "description": "User preferences."
        }
      }
    ]
  }
}
