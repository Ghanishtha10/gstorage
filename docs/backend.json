
{
  "entities": {
    "File": {
      "title": "File",
      "type": "object",
      "description": "Represents an uploaded file, including its metadata and relationships to tags.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "thumbnailUrl": { "type": "string", "format": "uri" },
        "type": { "type": "string" },
        "mimeType": { "type": "string" },
        "size": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "isDownloadable": { "type": "boolean" }
      },
      "required": ["id", "name", "url", "type", "uploadedAt"]
    },
    "PublicProfile": {
      "title": "PublicProfile",
      "type": "object",
      "description": "Public administrative profile details.",
      "properties": {
        "displayName": { "type": "string" },
        "bio": { "type": "string", "description": "Short tagline or role title." },
        "aboutMe": { "type": "string", "description": "Detailed multi-line paragraph." },
        "photoURL": { "type": "string", "format": "uri" },
        "discord": { "type": "string" },
        "twitter": { "type": "string" },
        "github": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/files/{fileId}": {
      "schema": { "$ref": "#/backend/entities/File" },
      "description": "Metadata for uploaded files."
    },
    "/public_profiles/{profileId}": {
      "schema": { "$ref": "#/backend/entities/PublicProfile" },
      "description": "Public identity information."
    }
  }
}
